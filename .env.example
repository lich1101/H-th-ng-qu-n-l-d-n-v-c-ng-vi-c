APP_NAME="Jobs ClickOn"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_GRAPH_VERSION=v23.0

FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_SENDER_ID=
FIREBASE_WEB_APP_ID=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=internal_task_manager
DB_USERNAME=root
DB_PASSWORD=
SEED_ONLY_USERS=false

BROADCAST_DRIVER=log
# Cache: API throttle + RateLimiter. file = cần quyền ghi storage/framework/cache/data
# Lỗi lockable file trên server → chmod -R ug+rwx storage bootstrap/cache (user www-data/nginx tùy host)
# database: chạy `php artisan migrate` (migration create cache table) TRƯỚC khi đặt CACHE_DRIVER=database,
# hoặc tạm để CACHE_DRIVER=file rồi migrate, sau đó đổi lại + php artisan config:clear
# redis: cần Redis + REDIS_* đúng
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="no-reply@noibo.local"
MAIL_FROM_NAME="Jobs ClickOn"

MIX_API_BASE_URL=http://127.0.0.1:8000/api/v1
MOBILE_APP_DEEPLINK=internal://
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:3000

# Deadline reminder channels
DEADLINE_CHANNELS=in_app,push
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DEADLINE_TELEGRAM_WEBHOOK=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_RECIPIENT_ID=
ZALO_OA_API_URL=https://openapi.zalo.me/v3.0/oa/message
DEADLINE_ZALO_WEBHOOK=
WORKLOAD_THRESHOLD=8

# Lead capture
LEAD_WEBHOOK_TOKEN=
